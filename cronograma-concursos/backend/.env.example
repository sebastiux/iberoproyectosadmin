# Database. Railway's Postgres plugin injects DATABASE_URL automatically.
# Local default: sqlite:///./cronograma.db
DATABASE_URL=sqlite:///./cronograma.db

# Primary frontend origin (used for CORS). Add extras via EXTRA_CORS_ORIGINS.
FRONTEND_ORIGIN=http://localhost:3000
EXTRA_CORS_ORIGINS=

ENVIRONMENT=development
LOG_LEVEL=INFO
