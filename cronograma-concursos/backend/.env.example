# Database. Railway's MySQL plugin exposes the URL as MYSQL_URL — copy it
# into DATABASE_URL on the backend service. Local default uses SQLite.
# Examples:
#   sqlite:///./cronograma.db
#   mysql+pymysql://user:password@host:3306/railway
DATABASE_URL=sqlite:///./cronograma.db

# Primary frontend origin (used for CORS). Add extras via EXTRA_CORS_ORIGINS.
FRONTEND_ORIGIN=http://localhost:3000
EXTRA_CORS_ORIGINS=

ENVIRONMENT=development
LOG_LEVEL=INFO
