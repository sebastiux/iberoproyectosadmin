# Database. Two options — the app picks the first one that resolves:
#
# 1) Full connection URL (takes precedence when set). Locally this defaults
#    to SQLite; on Railway you can point it at ${{MySQL.MYSQL_URL}}.
#DATABASE_URL=sqlite:///./cronograma.db
#
# 2) Individual MySQL parts. Matches the variable names Railway's MySQL
#    plugin exposes, so you can paste each one as-is (or link them via
#    Variable References pointing at the MySQL service).
#MYSQLHOST=mysql.railway.internal
#MYSQLPORT=3306
#MYSQLUSER=root
#MYSQLPASSWORD=change-me
#MYSQLDATABASE=railway

# Primary frontend origin (used for CORS). Add extras via EXTRA_CORS_ORIGINS.
FRONTEND_ORIGIN=http://localhost:3000
EXTRA_CORS_ORIGINS=

ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Auth ---
# Comma-separated entries. Each entry is "user:password" or
# "user:password:email@domain". The email is optional; when present AND
# Resend is configured, login becomes a 2-step flow (password, then a
# 6-digit code emailed via Resend).
AUTH_USERS=admin:changeme:admin@example.com
# Random string used to sign session tokens. Set this in production so
# tokens survive restarts. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET=

# --- Email (Resend) ---
# Get a key at https://resend.com. Leaving this empty disables 2-step
# login (password-only) and silently no-ops the alert/weekly emails.
RESEND_API_KEY=
# Verified sender. The "onboarding@resend.dev" sandbox sender works for
# Resend's own test inbox; switch to your verified domain in production.
RESEND_FROM=Cronograma <onboarding@resend.dev>

# --- Alerts ---
# Where alert + weekly emails go. If empty, falls back to every email in
# AUTH_USERS.
ALERT_RECIPIENTS=
# Scheduler config. Daily delay alert runs at ALERT_DAILY_HOUR; weekly
# Monday report runs at WEEKLY_REPORT_HOUR. Both in SCHEDULER_TIMEZONE.
SCHEDULER_TIMEZONE=America/Mexico_City
ALERT_DAILY_HOUR=9
WEEKLY_REPORT_HOUR=8

# Public URL of the frontend, embedded as a link in outgoing emails.
PUBLIC_APP_URL=http://localhost:3000
